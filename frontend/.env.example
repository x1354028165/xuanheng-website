# ============================================================
# 旭衡电子官网 — 前端环境变量模板
# 复制为 .env.local 并填入真实值，禁止提交 .env.local 到 git
# ============================================================

# --- Strapi CMS ---
NEXT_PUBLIC_API_URL=http://localhost:1337
STRAPI_PUBLIC_TOKEN=           # 只读 Token，Strapi Admin → Settings → API Tokens
STRAPI_WRITE_TOKEN=            # 写权限 Token，仅用于服务端 Route Handler

# --- 站点配置 ---
NEXT_PUBLIC_SITE_URL=https://alwayscontrol.com.cn
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN

# --- CDN / 媒体 ---
NEXT_PUBLIC_CDN_DOMAIN=        # 生产：cdn.alwayscontrol.com.cn，本地留空

# --- Cloudflare Turnstile（表单防刷） ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # 前端可见，Cloudflare 后台获取
TURNSTILE_SECRET_KEY=             # 仅服务端，Cloudflare 后台获取

# --- ISR 缓存刷新 ---
REVALIDATE_SECRET=             # 随机 32 位，与 Strapi Webhook Header 保持一致
