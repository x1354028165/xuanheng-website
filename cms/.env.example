# ============================================================
# 旭衡电子官网 — CMS (Strapi) 环境变量模板
# 复制为 .env 并填入真实值，禁止提交 .env 到 git
# ============================================================

# --- 服务配置 ---
HOST=0.0.0.0
PORT=1337
APP_KEYS=                      # 4个逗号分隔随机串：openssl rand -base64 32（生成4次）
API_TOKEN_SALT=                # openssl rand -hex 32
ADMIN_JWT_SECRET=              # openssl rand -hex 32
TRANSFER_TOKEN_SALT=           # openssl rand -hex 32
JWT_SECRET=                    # openssl rand -hex 32

# --- 数据库（开发用 SQLite，生产换 PostgreSQL） ---
DATABASE_CLIENT=sqlite         # 生产改为：postgresql
# DATABASE_HOST=               # PostgreSQL 主机
# DATABASE_PORT=5432
# DATABASE_NAME=xuanheng_prod
# DATABASE_USERNAME=
# DATABASE_PASSWORD=

# --- AI 翻译 ---
DEEPSEEK_API_KEY=              # 已获取：sk-e952bf0551ca4e2b843035c6aa02cecc

# --- 文件存储（开发用本地，生产换阿里云 OSS） ---
# AWS_ACCESS_KEY_ID=           # 阿里云 OSS AccessKey ID
# AWS_ACCESS_SECRET=           # 阿里云 OSS AccessKey Secret
# AWS_REGION=oss-cn-shenzhen
# AWS_BUCKET=xuanheng-prod
# AWS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
# CDN_URL=https://cdn.alwayscontrol.com.cn

# --- 邮件（联调阶段配置） ---
# SMTP_HOST=smtp.aliyun.com
# SMTP_PORT=465
# SMTP_USER=noreply@alwayscontrol.com.cn
# SMTP_PASS=

# --- 通知（联调阶段配置） ---
# WECOM_WEBHOOK_URL=           # 企业微信销售群 Webhook

# --- 前端 ISR 刷新 ---
REVALIDATE_SECRET=             # 与前端 REVALIDATE_SECRET 保持一致，随机 32 位
NEXT_PUBLIC_URL=http://localhost:3000  # 生产改为 https://alwayscontrol.com.cn
