    "summary": { "type": "text" },
    "content": { "type": "richtext" },
    "cover": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "client": { "type": "string" },
    "location": { "type": "string" },
    "solutionType": { "type": "string" },
    "sortOrder": { "type": "integer", "default": 0 }
  }
}
