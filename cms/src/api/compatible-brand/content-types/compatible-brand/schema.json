{
  "kind": "collectionType",
  "collectionName": "compatible_brands",
  "info": {
    "singularName": "compatible-brand",
    "pluralName": "compatible-brands",
    "displayName": "兼容品牌"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": { "localized": false }
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "logo": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "category": { "type": "json" },
    "websiteUrl": { "type": "string" },
    "sortOrder": { "type": "integer", "default": 0 },
    "isVisible": { "type": "boolean", "default": true },
    "integrationLevel": {
      "type": "enumeration",
      "enum": ["read", "read_history", "full_control"],
      "default": "read"
    },
    "accessMethod": {
      "type": "enumeration",
      "enum": ["cloud", "gateway", "both"],
      "default": "both"
    },
    "supportStatus": {
      "type": "enumeration",
      "enum": ["connected", "adapting"],
      "default": "connected"
    },
    "showOnHomepage": { "type": "boolean", "default": true }
  }
}
